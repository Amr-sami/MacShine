{
  "name": "macshine",
  "version": "0.1.0",
  "private": true,
  "description": "MacShine - The ultimate macOS desktop app for disk cleanup and system health",
  "scripts": {
    "dev": "concurrently \"pnpm --filter macshine-web dev\" \"pnpm --filter @macshine/desktop dev\"",
    "build": "pnpm --filter macshine-web build",
    "build:web": "pnpm --filter macshine-web build",
    "build:desktop": "pnpm --filter @macshine/desktop build",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "esbuild"],
    "overrides": {
      "@types/react": "18.2.0",
      "@types/react-dom": "18.2.0"
    }
  }
}
